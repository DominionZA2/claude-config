{
    "folders": [
        {
            "name": "v2-portal",
            "path": "v2-portal"
        },
        {
            "name": "cloud_backend",
            "path": "cloud_backend"
        }
    ],
    "settings": {
        "files.eol": "\r\n",
        "editor.renderWhitespace": "all"
    },
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "build AuraServices",
                "type": "shell",
                "command": "/usr/local/share/dotnet/dotnet",
                "args": [
                    "build",
                    "AuraServices.sln"
                ],
                "options": {
                    "cwd": "${workspaceFolder:cloud_backend}"
                },
                "problemMatcher": [ "$msCompile" ],
                "group": {
                    "kind": "build",
                    "isDefault": true
                }
            }
        ]
    }
}
